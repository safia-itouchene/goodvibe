# =============================================================================
# GoodVibe – Environment Variables Example
# =============================================================================
# Copy this file to .env (or .env.local for the frontend) and fill in the
# values below.  NEVER commit your actual .env file – it contains secrets!
#
# -----------------------------------------------------------------------------
# FRONTEND (Vite) – used by the React app
# -----------------------------------------------------------------------------

# URL of the GoodVibe backend server (see server/README or server/index.js)
# Local development:
VITE_API_URL=http://localhost:3001
# Production (replace with your actual backend URL):
# VITE_API_URL=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# BACKEND (Node.js server in /server) – used by server/index.js
# -----------------------------------------------------------------------------

# Port the Express server listens on (default: 3001)
PORT=3001

# Comma-separated list of allowed frontend origins for CORS.
# Add your production frontend URL here when deploying.
# Example: ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# --- Google Sheets API credentials ---
#
# How to obtain these values:
#   1. Go to https://console.cloud.google.com/
#   2. Create or select a project
#   3. Enable the "Google Sheets API" under APIs & Services → Library
#   4. Go to APIs & Services → Credentials
#   5. Create a Service Account and download the JSON key file
#   6. Copy client_email and private_key from the JSON file into the fields below
#   7. Share your Google Sheet with the service account email (Editor access)
#
# Service account email (client_email from the JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key from the JSON key file.
# Keep the quotes and preserve the literal \n characters – dotenv will handle them.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Google Sheet configuration ---
#
# Spreadsheet ID – found in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet name and column range to append orders to.
# The default assumes a sheet tab named "Orders" with columns A through K.
# Adjust the range if you rename the tab or add/remove columns.
GOOGLE_SHEET_RANGE=Orders!A:K
